---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const guidePosts = allPosts
  .filter(post => post.data.category !== 'nyheter')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

export const prerender = false;
---

<BaseLayout title="Alla Guider" description="Djupdyk i våra guider om Home Assistant, Zigbee och smarta hem.">
  <div class="blog-header">
    <div class="container">
      <h1>Guider & Tips</h1>
      <p>Lär dig bygga och optimera ditt smarta hem från grunden.</p>
    </div>
  </div>

  <div class="container section">
    <div class="articles-grid">
      {guidePosts.map(post => (
        <a href={`/blog/${post.slug}`} class="article-card">
          <div class="article-card-image">
            {post.data.heroImage ? (
              <img src={post.data.heroImage} alt={post.data.title} />
            ) : (
              <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #e2e8f0;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              </div>
            )}
            {post.data.category && (
              <span class="article-card-category" style="text-transform: capitalize;">{post.data.category}</span>
            )}
          </div>
          <div class="article-card-content">
            <h2 class="article-card-title">{post.data.title}</h2>
            <p class="article-card-excerpt">{post.data.description}</p>
            <div class="article-card-meta">
              <span>{new Intl.DateTimeFormat('sv-SE', { year: 'numeric', month: 'long', day: 'numeric' }).format(post.data.pubDate)}</span>
            </div>
          </div>
        </a>
      ))}
      {guidePosts.length === 0 && (
        <p>Inga guider publicerade ännu.</p>
      )}
    </div>
  </div>
</BaseLayout>
